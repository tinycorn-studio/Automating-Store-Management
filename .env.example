# ============================================================
# AutoStoreSetup - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
# ============================================================

# --- Google Play Console ---
# The Android package name / application ID
GOOGLE_PLAY_PACKAGE_NAME=com.studio.game

# Path to the Google Cloud service account JSON key file
# (Must have "Android Publisher" API access AND "Google Sheets" API access)
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json

# --- Apple App Store Connect ---
# Your App Store Connect API Key ID (from the Keys page)
APPLE_KEY_ID=XXXXXXXXXX

# Your App Store Connect Issuer ID
APPLE_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Path to the .p8 private key file downloaded from App Store Connect
APPLE_PRIVATE_KEY_PATH=./credentials/AuthKey_XXXXXXXXXX.p8

# Your App's Apple ID (numeric, found in App Store Connect > App Information)
APPLE_APP_ID=1234567890

# --- Data Source ---
# Choose one: "excel" (local .xlsx file) or "gsheet" (Google Sheets online)
DATA_SOURCE=gsheet

# Used when DATA_SOURCE=excel
IAP_DATA_FILE=./iap_data.xlsx

# Used when DATA_SOURCE=gsheet
# The Spreadsheet ID from the Google Sheets URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEET_ID=your-spreadsheet-id-here

# (Optional) Worksheet name inside the spreadsheet. Defaults to first sheet.
GOOGLE_SHEET_WORKSHEET=Sheet1

# --- Operation Mode ---
# Set to "true" to skip actual API calls and only simulate (dry-run)
DRY_RUN=true
